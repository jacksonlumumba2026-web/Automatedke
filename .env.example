# ---------------------------------------------------------------------------
# Copy to .env.local (apps/web) for local development.
# NEVER commit a file containing real values.
# Staging and production values are set independently in Vercel — see
# Deployment_Architecture.md, Section 4.
# ---------------------------------------------------------------------------

# Public — safe to expose to the browser (Supabase's anon key is designed
# for this; access control is enforced by RLS, not by keeping this secret).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER prefixed with NEXT_PUBLIC_, NEVER imported into a
# "use client" file. Bypasses Row Level Security. See lib/supabase/admin.ts.
SUPABASE_SERVICE_ROLE_KEY=

# Used by `pnpm db:types` to generate packages/types/database.types.ts
SUPABASE_PROJECT_ID=

# OAuth (configured primarily in the Supabase Auth dashboard; app-side
# values only needed if a provider requires a redirect allow-list entry
# managed from this codebase)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
